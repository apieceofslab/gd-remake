<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>GD Engine RTX</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="style.css">
</head>
<body>

<div id="start-screen">
  <h1>GD ENGINE RTX</h1>
  <button onclick="startGame()">PLAY</button>
</div>

<div id="progress-bg"><div id="progress-fill"></div></div>
<div id="stats-left">DEATHS: <span id="death-count">0</span></div>
<div id="stats"><span id="percent">0</span>%</div>
<div id="fps-counter">FPS: 0</div>

<button id="quality-btn">QUALITY: RTX ON</button>

<div id="pause-overlay">
  <h2>PAUSED</h2>
  <button onclick="togglePause()">RESUME</button>
</div>

<div id="editor-ui"></div>

<canvas id="game"></canvas>

<script src="main.js" type="module"></script>
</body>
</html>
